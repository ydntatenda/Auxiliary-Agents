OPENAI_API_KEY=
GOOGLE_API_KEY=
DATABASE_URL=postgresql+asyncpg://agentic_ops:agentic_ops@localhost:5432/agentic_ops
FRONTEND_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads
OPENAI_EXTRACTION_MODEL=gpt-5.4
OPENAI_RENDER_MODEL=gpt-5
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_CLARIFICATION_MODEL=gpt-5.4
GEMINI_VIDEO_MODEL=gemini-2.5-pro

# Clarification provider toggle. Set to "openrouter" to route the clarification
# agent through OpenRouter (e.g. Moonshot Kimi). Default is OpenAI.
CLARIFICATION_PROVIDER=openai
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CLARIFICATION_MODEL=moonshotai/kimi-k2.6
